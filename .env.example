# Non-secret examples only. Inject real secrets through your deployment secret manager.
GITHUB_TOKEN=
REASONING_API_MODEL=claude-4.6-opus
REASONING_PRIVATE_KEY=
REASONING_WALLET_CHAIN=ltc
REASONING_WALLET_ADDRESS=
REASONING_MONEY=10
REASONING_MONEY_ID=
REASONING_SIGNER_COMMAND=
RESEND_MANAGEMENT_API_KEY=
GITHUB_AI_MAIL_TEST_TO=
GITHUB_AI_MAIL_BACKEND=auto

# Optional override when the agent environment has a dedicated Agent Mail sender.
# Example: Agent Mail <agent@verified.example>
GITHUB_AI_MAIL_FROM=

# Required on headless Linux when no usable Secret Service is available.
# Commands receive the secret name as their final argument.
# PUT receives the secret value on stdin; GET writes it to stdout.
GITHUB_AI_SECRET_GET_CMD=
GITHUB_AI_SECRET_PUT_CMD=
GITHUB_AI_SECRET_DELETE_CMD=
